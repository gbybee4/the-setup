alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

alias mv='mv -i'
alias cp='cp -i'
alias rm='rm -i'

alias lh='ls -haltr'

alias mkdirs='mkdir -pv'

alias fd='fdfind'

alias qr='quick-run'

alias tf='terraform'
alias kc='kubectl'

alias vim='nvim'
alias vi='nvim'
alias svi='sudo nvim'

alias cat='batcat'
